{
  "name": "windlint",
  "version": "0.0.1",
  "type": "module",
  "description": "Lint and rename CSS variables and design tokens in Tailwind CSS v4 projects",
  "bin": {
    "windlint": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" && pnpm build",
    "test": "vitest"
  },
  "keywords": [
    "css",
    "lint",
    "rename",
    "tailwind",
    "design-tokens",
    "codemod",
    "migration",
    "css-variables",
    "custom-properties"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/css-rename"
  },
  "homepage": "https://github.com/remorses/css-rename",
  "bugs": "https://github.com/remorses/css-rename/issues",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/oxide": "^4.2.4",
    "globby": "^14.1.0",
    "goke": "^6.6.0",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
